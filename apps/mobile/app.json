{
  "expo": {
    "name": "Founders Tribe",
    "slug": "founders-tribe",
    "scheme": "appfounderstribe",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/images/logo-dark.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.founderstribe.ai",
      "associatedDomains": ["applinks:founderstribe.in"],
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "icon": "./assets/images/play_store_512.png",
      "usesAppleSignIn": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/play_store_512.png"
      },
      "package": "com.founderstribe.ai",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "founderstribe.in",
              "pathPrefix": "/room"
            },
            {
              "scheme": "https",
              "host": "founderstribe.in",
              "pathPrefix": "/article"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo-light.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FAFAF9",
          "dark": {
            "image": "./assets/images/logo-dark.png",
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/BricolageGrotesque_400Regular.ttf",
            "./assets/fonts/BricolageGrotesque_600SemiBold.ttf",
            "./assets/fonts/BricolageGrotesque_700Bold.ttf",
            "./assets/fonts/Poppins_400Regular.ttf",
            "./assets/fonts/Poppins_500Medium.ttf",
            "./assets/fonts/Poppins_600SemiBold.ttf",
            "./assets/fonts/Poppins_700Bold.ttf"
          ]
        }
      ],
      "@livekit/react-native-expo-plugin"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7cc0552f-8136-4858-93df-978beedb3222"
      }
    }
  }
}
