{
  "outputDirectory": "apps/website",
  "headers": [
    {
      "source": "/.well-known/apple-app-site-association",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/json"
        }
      ]
    },
    {
      "source": "/.well-known/assetlinks.json",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/json"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/room/:id",
      "destination": "/room.html"
    },
    {
      "source": "/article/:id",
      "destination": "/article.html"
    }
  ]
}
